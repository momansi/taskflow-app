apiVersion: apps/v1
kind: Deployment
metadata:
  name: backend
  namespace: taskflow-app
spec:
  replicas: 1
  selector:
    matchLabels:
      app: backend
  template:
    metadata:
      labels:
        app: backend
    spec:
      containers:
        - name: backend-container 
          image: muhammadelmansi/taskflow-backend:{{ image_tag }}
          imagePullPolicy: Always
          ports:
            - containerPort: 3000
          env:
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: taskflow-secret
                  key: postgres-password
            - name: POSTGRES_USER
              valueFrom:
                configMapKeyRef:
                  name: taskflow-config
                  key: postgres-user
            - name: POSTGRES_HOST
              valueFrom:
                configMapKeyRef:
                  name: taskflow-config
                  key: postgres-host
            - name: POSTGRES_DB
              valueFrom:
                configMapKeyRef:
                  name: taskflow-config
                  key: postgres-db
---
apiVersion: v1
kind: Service
metadata:
  name: backend-svc
  namespace: taskflow-app
spec:
  selector:
    app: backend
  ports:
    - port: 3000 
      targetPort: 3000