apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend 
  namespace: taskflow-app
spec:
  replicas: 1
  selector:
    matchLabels:
      app: frontend
  template:
    metadata:
      labels:
        app: frontend
    spec:
      containers:
        - name: frontend-container 
          image: muhammadelmansi/taskflow-frontend:{{ image_tag }}
          imagePullPolicy: Always
          resources:
            requests:
              cpu: "100m"
              memory: "128Mi"
            limits:
              cpu: "500m"
              memory: "256Mi"
          ports:
            - containerPort: 80
---
apiVersion: v1 
kind: Service
metadata:
  name: frontend-svc 
  namespace: taskflow-app
spec:
  selector:
    app: frontend
  ports:
    - port: 80
      targetPort: 80